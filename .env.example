# ============================================
# IMPERMEABILITZACIONS BCN — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# ============================================

# Base de datos — NeonDB (PostgreSQL serverless)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/impermeabilitzacions?sslmode=require"

# NextAuth — Autenticación
AUTH_SECRET="genera-uno-con: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# OAuth Providers (opcional — añade los que necesites)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# Email — Resend (para formulario de contacto)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="contacte@impermeabilitzacionsbcn.cat"
EMAIL_TO="info@impermeabilitzacionsbcn.cat"

# WhatsApp — Número de empresa (formato internacional sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER="34600000000"
NEXT_PUBLIC_WHATSAPP_MESSAGE="Hola! M'agradaria demanar un pressupost gratuït per impermeabilització."

# Empresa — Datos públicos
NEXT_PUBLIC_COMPANY_PHONE="+34 93 000 00 00"
NEXT_PUBLIC_COMPANY_EMAIL="info@impermeabilitzacionsbcn.cat"
NEXT_PUBLIC_COMPANY_ADDRESS="Barcelona, Catalunya"

# Analytics (opcional)
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_HOTJAR_ID=""

# Entorno
NODE_ENV="development"
